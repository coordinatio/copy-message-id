{
  "manifest_version": 2,
  "applications": {
    "gecko": {
      "id": "copy-message-id@j.kahn",
      "strict_min_version": "68.7.0"
    }
  },
  "name": "Copy Message ID",
  "description": "Adds a button to the message view toolbar to copy the message ID to the clipboard",
  "options_ui": {
    "page": "options/options.html"
  },
  "permissions": [
    "storage",
    "messagesRead",
    "clipboardWrite"
  ],
  "message_display_action": {
    "default_title": "Copy Message ID",
    "default_icon": "icons/button.png",
    "default_popup": "popup/popup.html"
  },
  "commands": {
    "copy-message-id": {
      "suggested_key": {
        "default": "Ctrl+Alt+O"
      },
      "description": "Copy Message ID"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "version": "1.4.1"
}
