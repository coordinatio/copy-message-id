{
  "manifest_version": 2,
  "browser_specific_settings": {
    "gecko": {
      "id": "copy-message-id@j.kahn",
      "strict_min_version": "91.0"
    }
  },
  "name": "Copy Message ID and Subject",
  "description": "Adds a toolbar button to copy either the message Subject or the Message-ID to the clipboard",
  "options_ui": {
    "page": "options/options.html"
  },
  "permissions": [
    "storage",
    "messagesRead",
    "clipboardWrite",
    "menus"
  ],
  "message_display_action": {
    "default_title": "Copy Message ID / Subject",
    "default_icon": "icons/button.png",
    "type": "menu"
  },
  "commands": {
    "copy-message-id": {
      "suggested_key": {
        "default": "Ctrl+Alt+O"
      },
      "description": "Copy Message ID"
    },
    "copy-subject": {
      "suggested_key": {
        "default": "Ctrl+Alt+A"
      },
      "description": "Copy Subject"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "version": "1.6.0"
}
